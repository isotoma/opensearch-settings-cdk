{
    "name": "opensearch-settings-cdk",
    "version": "1.0.0",
    "description": "Apply cluster settings to ES domains",
    "license": "MIT",
    "author": {
        "name": "Isotoma Limited",
        "email": "hello@isotoma.com",
        "url": "https://isotoma.com"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/isotoma/opensearch-settings-cdk"
    },
    "keywords": [
        "cdk",
        "opensearch"
    ],
    "scripts": {
        "test": "jest",
        "tsc": "tsc",
        "clean": "rm -rf build/",
        "compile": "npm run clean && npm run -- tsc --outDir build/ && (cd provider && npm install && npm run compile) && mkdir -p ./build/provider && cp -R ./provider/build/ ./build/provider/ && cp package.json README.md ./build/",
        "version": "auto-changelog --template ./changelog_template.hbs -p && git add CHANGELOG.md",
        "lint": "eslint 'index.ts' 'test/**/*.ts' --quiet --fix",
        "lint-check": "eslint 'index.ts' 'test/**/*.ts' --max-warnings 0"
    },
    "peerDependencies": {
        "aws-cdk-lib": "^2.0.0",
        "constructs": "^10.0.0"
    },
    "devDependencies": {
        "@types/jest": "^29.0.0",
        "@types/node": "^20.0.0",
        "@typescript-eslint/eslint-plugin": "2.16.0",
        "@typescript-eslint/parser": "2.16.0",
        "auto-changelog": "^1.16.2",
        "aws-cdk-lib": "^2.179.0",
        "constructs": "^10.4.0",
        "eslint": "6.8.0",
        "eslint-config-prettier": "6.9.0",
        "eslint-plugin-prettier": "3.1.2",
        "jest": "^29.0.0",
        "prettier": "1.19.1",
        "ts-jest": "^29.0.0",
        "typescript": "^5.4.0"
    }
}
